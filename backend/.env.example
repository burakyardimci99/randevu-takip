# ============================================================
# Kuveyt Türk AI Lab - Backend Environment Variables
# ============================================================
# UYARI (data_security.md §1): Bu dosyayı .env olarak kopyalayın
# ve gerçek değerlerle doldurun. .env dosyasını ASLA commit etmeyin.
# Production'da kurumsal kasa (Vault/KMS) kullanın.
# ============================================================

# Server
NODE_ENV=development
PORT=4000
HOST=127.0.0.1

# CORS — Frontend origin (wildcard yasak — app_security §6)
FRONTEND_ORIGIN=http://localhost:5173

# JWT Keys (RS256 — HS256 yasak — app_security §4)
# Bu yolları değiştirmeyin; `npm run keys:generate` ile üretilir
USER_JWT_PRIVATE_KEY_PATH=./keys/user_private.pem
USER_JWT_PUBLIC_KEY_PATH=./keys/user_public.pem
ADMIN_JWT_PRIVATE_KEY_PATH=./keys/admin_private.pem
ADMIN_JWT_PUBLIC_KEY_PATH=./keys/admin_public.pem

# JWT TTL (saniye)
USER_ACCESS_TOKEN_TTL=900
USER_REFRESH_TOKEN_TTL=604800
ADMIN_ACCESS_TOKEN_TTL=900
ADMIN_REFRESH_TOKEN_TTL=604800

# JWT Audience & Issuer
JWT_ISSUER=klab-randevu
USER_JWT_AUDIENCE=klab-user
ADMIN_JWT_AUDIENCE=klab-admin

# Database — PostgreSQL (ZORUNLU). Sistem yalnız pg ile çalışır.
DATABASE_URL=postgres://klab:klab_dev_password@localhost:5432/klab

# CSRF
CSRF_SECRET=CHANGE_ME_RUNTIME_GENERATED_VALUE_AT_LEAST_32_CHARS_LONG

# Brute force koruması
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=10

# Log seviyesi
LOG_LEVEL=info

# Bakım / Audit retention (data_security §11) — SQLite şişmesini önler
# Yaş bazlı retention (gün). 0 = silme. Bankacılık tipik 365; demo/dev için kısalt (örn. 30).
AUDIT_RETENTION_DAYS=365
# Hacim sınırı — en yeni N audit kaydı tutulur (yüksek log üretiminde dosya patlamasın). 0 = sınırsız.
AUDIT_MAX_ROWS=200000
# Silme sonrası VACUUM ile boş alanı diske geri ver. 'false' = kapat.
AUDIT_VACUUM=true

# Görsel üretimi (gorsel_uretim entegrasyonu)
# Provider: 'pollinations' | 'gemini'
IMAGE_PROVIDER=pollinations
# Pollinations artık ANONİM erişimde 402 (ödeme) veriyor → ücretsiz token GEREKİR.
# auth.pollinations.ai üzerinden GitHub ile ücretsiz token al, buraya yapıştır.
# Token yalnız sunucu tarafında Authorization header ile kullanılır (URL'e sızmaz).
# POLLINATIONS_TOKEN=
# Gemini 2.5 Flash Image — güvenilir, 500 görsel/gün ücretsiz. IMAGE_PROVIDER=gemini ile aktif.
# GEMINI_API_KEY=
# UYARI (data_security §8): görsel üretimi proje fikrini üçüncü-taraf AI servisine gönderir.
# Production'da kurumsal-gated/self-hosted model + PII scrubber gerekir.
