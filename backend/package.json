    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "winston": "^3.15.0",
