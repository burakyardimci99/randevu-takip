# Production ortam değişkenleri — kopyala: cp .env.prod.example .env.prod
# .env.prod ASLA commit edilmez (.gitignore + .dockerignore kapsamında).
# Çalıştırma: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- PostgreSQL ---
POSTGRES_USER=klab
POSTGRES_PASSWORD=__GÜÇLÜ_RASTGELE_PAROLA__
POSTGRES_DB=klab

# --- Uygulama ---
# Frontend'in servis edileceği genel origin (CORS + cookie domain için).
FRONTEND_ORIGIN=https://randevu.klab.example
# CSRF imza sırrı — min 32 karakter. Üret: openssl rand -base64 48
CSRF_SECRET=__OPENSSL_RAND_BASE64_48__
# Dışarı açılacak HTTP portu (TLS termination önünde bir LB varsa 80 kalır).
HTTP_PORT=80
LOG_LEVEL=info

# --- Görsel üretimi (Pollinations) ---
IMAGE_PROVIDER=pollinations
# enter.pollinations.ai'den alınan sk_ (secret) API anahtarı. YALNIZ server-side.
POLLINATIONS_TOKEN=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# NOT: JWT anahtarları env'de DEĞİL — backend/keys/*.pem dosyaları salt-okunur
# volume ile mount edilir. Üret: cd backend && npm run keys:generate
